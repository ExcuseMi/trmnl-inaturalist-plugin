{% template main %}
{% liquid
  assign fields = trmnl.plugin_settings.custom_fields_values.overlay_fields | default: "species, location, observer, date"
%}

<style>
  .inat-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  .inat-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .inat-overlay {
    position: absolute;
    bottom: 5px;
    left: 5px;
    background-color: black;
    color: white;
    padding: 5px 12px 6px;
    border-radius: 7px;
    z-index: 10;
    max-width: calc(100% - 20px);
  }
  .inat-species   { display: block; font-weight: bold; font-size: 0.8rem; }
  .inat-scientific{ display: block; font-style: italic; font-size: 0.65rem; }
  .inat-location  { display: block; font-size: 0.65rem; }
  .inat-date      { display: block; font-size: 0.6rem; }
  .inat-credit    { display: block; font-size: 0.6rem; opacity: 0.85; }
  .inat-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 8px;
  }
</style>

<script>var __inat = {{ items | json }};</script>

<div class="layout layout--stretch gap--none m--0 p--0 inat-wrap" id="inat-root">
  <img class="image image-dither inat-photo" src="" alt="" id="inat-img" style="display:none;" />
  <div class="inat-overlay" id="inat-overlay" style="display:none;">
    {% if fields contains 'species' %}
      <span class="inat-species" id="inat-species"></span>
    {% endif %}
    {% if fields contains 'scientific' %}
      <span class="inat-scientific" id="inat-scientific"></span>
    {% endif %}
    {% if fields contains 'location' %}
      <span class="inat-location" id="inat-location"></span>
    {% endif %}
    {% if fields contains 'date' %}
      <span class="inat-date" id="inat-date"></span>
    {% endif %}
    {% if fields contains 'observer' or fields contains 'license' %}
      <span class="inat-credit" id="inat-credit"></span>
    {% endif %}
  </div>
  <div class="inat-empty" id="inat-empty" style="display:none;">
    <span class="label label--small">iNaturalist</span>
    <span class="description text--center">{{ error | default: 'No observations found.' }}</span>
  </div>
</div>

<script>
(function() {
  var root   = document.getElementById('inat-root');
  var views  = Array.from(document.querySelectorAll('.view'));
  var host   = views.find(function(v) { return v.contains(root); });
  var idx    = host ? views.indexOf(host) % 4 : 0;
  var item   = (__inat || [])[idx] || null;

  if (!item || !item.photo_url) {
    document.getElementById('inat-empty').style.display = '';
    return;
  }

  var img = document.getElementById('inat-img');
  img.src = item.photo_url;
  img.style.display = '';

  var hasOverlay = false;
  function setText(id, val) {
    var el = document.getElementById(id);
    if (el) { el.textContent = val || ''; if (val) hasOverlay = true; }
  }

  setText('inat-species',    item.species);
  setText('inat-scientific', item.scientific);
  setText('inat-location',   item.location);
  setText('inat-date',       item.observed_on);

  var credit = document.getElementById('inat-credit');
  if (credit) {
    var parts = [];
    if (item.observer) parts.push('© ' + item.observer);
    if (item.license)  parts.push(item.license);
    var val = parts.join(' · ');
    credit.textContent = val;
    if (val) hasOverlay = true;
  }

  if (hasOverlay) document.getElementById('inat-overlay').style.display = '';
})();
</script>
{% endtemplate %}
