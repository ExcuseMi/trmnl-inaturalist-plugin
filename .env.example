BACKEND_PORT=8743

# IP whitelist (set false for local dev)
ENABLE_IP_WHITELIST=false
IP_REFRESH_HOURS=24

# How often to fetch fresh observations per unique filter combo (hours)
FETCH_INTERVAL_HOURS=24

# Comma-separated iNaturalist photo license codes to accept.
# CC BY and CC0 are safest for commercial use. Add cc-by-nc etc. to widen the pool.
# Full list: cc-by, cc-by-nc, cc-by-sa, cc-by-nd, cc-by-nc-sa, cc-by-nc-nd, cc0
PHOTO_LICENSES=cc0,cc-by,cc-by-sa,cc-by-nd

# Number of observations to fetch per taxon+locale combination per day.
# iNaturalist returns max 200 per page; increase in steps of 200.
OBSERVATIONS_PER_FETCH=200

# PostgreSQL Configuration (used by Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
