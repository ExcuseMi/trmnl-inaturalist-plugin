{% template main %}
<style>
  .inat-img    { display: none; }
  .inat-empty  { display: none; position: absolute; inset: 0; align-items: center; justify-content: center; flex-direction: column; gap: 8px; }
  .inat-empty--visible { display: flex; }
  .inat-license { position: absolute; top: 5px; right: 5px; z-index: 50; display: none; background: rgba(0,0,0,0.55); color: #fff; font-size: 10px; line-height: 1; padding: 3px 6px; border-radius: 3px; }
  .inat-license--visible { display: block; }
  .inat-license--left { right: auto; left: 5px; }
  .inat-qr    { position: absolute; top: 5px; right: 5px; z-index: 100; background: white; padding: 2px; box-sizing: content-box; display: none; }
  .inat-qr--visible { display: block; }
</style>

<script>var __inat = {{ items | json }};</script>

{% if trmnl.plugin_settings.custom_fields_values.show_qr == "true" %}
  {% for item in items %}
  <div class="inat-qr inat-qr-{{ forloop.index0 }}">
    {{ item.inat_url | qr_code: 2, "m" }}
  </div>
  {% endfor %}
{% endif %}

<div class="layout layout--stretch gap--none m--0 p--0">
  <img class="image image-dither image--contain inat-img" src="" alt="" />
  <div class="inat-license"></div>
  <div class="inat-empty">
    <span class="label label--small">iNaturalist</span>
    <span class="description text--center">{{ error | default: 'No observations found.' }}</span>
  </div>
</div>

<div class="title_bar">
  <svg class="image h--8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
    <path d="M17 8C8 10 5.9 16.17 3.82 21H5.71C6.38 19.31 7.27 17.69 8.42 16.28C8.95 16.71 9.54 17.06 10.17 17.3C8.56 19.26 7.62 21.59 7.62 21.59H9.69C10.56 19.88 11.68 18.34 13.06 17.06C13.58 17.25 14.12 17.37 14.67 17.4C13.29 18.71 12.17 20.26 11.36 22H13.5C14.28 20.31 15.47 18.83 17 17.68C19.08 16.12 21 13.95 21 11C21 8.19 18.81 8 17 8M15 11.5C15 12.33 14.33 13 13.5 13C12.67 13 12 12.33 12 11.5C12 10.67 12.67 10 13.5 10C14.33 10 15 10.67 15 11.5Z"/>
  </svg>
  <span class="title inat-title"></span>
  <span class="instance inat-instance"></span>
</div>

<script>
(function() {
  var self   = document.currentScript;
  var views  = Array.from(document.querySelectorAll('.view'));
  var host   = views.find(function(v) { return v.contains(self); }) || document.body;
  var idx    = views.indexOf(host) % 4;
  var item   = (__inat || [])[idx] || null;

  if (!item || !item.photo_url) {
    var empty = host.querySelector('.inat-empty');
    if (empty) empty.classList.add('inat-empty--visible');
    return;
  }

  var img = host.querySelector('.inat-img');
  if (img) { img.src = item.photo_url; img.style.display = ''; }

  var titleEl = host.querySelector('.inat-title');
  if (titleEl) titleEl.textContent = item.species || item.scientific || '';

  var instanceEl = host.querySelector('.inat-instance');
  if (instanceEl) instanceEl.textContent = item.location || '';

  var qrEl = host.querySelector('.inat-qr-' + idx);
  if (qrEl) qrEl.classList.add('inat-qr--visible');

  var licenseEl = host.querySelector('.inat-license');
  if (licenseEl) {
    var attr = [];
    if (item.observer) attr.push('© ' + item.observer);
    if (item.license)  attr.push(item.license);
    if (attr.length) {
      licenseEl.textContent = attr.join(' · ');
      licenseEl.classList.add('inat-license--visible');
      if (qrEl) licenseEl.classList.add('inat-license--left');
    }
  }
})();
</script>
{% endtemplate %}
